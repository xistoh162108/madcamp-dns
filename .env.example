NODE_ENV=production
PORT=3000

# PostgreSQL — used by docker-compose to create the DB container
POSTGRES_USER=dnsapi
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=dnsapi

# Full connection string used by the API.
# Parameters:
#   connection_limit   — max DB connections this process holds open (default: CPU*2+10)
#   connect_timeout    — abort if DB doesn't accept the connection within N seconds (Prisma)
#   pool_timeout       — abort if no connection is available from the pool within N seconds (Prisma)
#   options=-c ...     — PostgreSQL session-level GUC parameters (libpq standard format)
#                        statement_timeout=5000 → kill queries running longer than 5 s (ms)
#                        %20 = space, %3D = =  (URL-encoded)
#
# For Docker Compose (db service on the same network):
DATABASE_URL=postgresql://dnsapi:change_me_in_production@db:5432/dnsapi?connection_limit=10&connect_timeout=10&pool_timeout=15&options=-c%20statement_timeout%3D5000

# For external/remote PostgreSQL (enforce SSL):
# DATABASE_URL=postgresql://dnsapi:change_me@your-db-host:5432/dnsapi?connection_limit=10&connect_timeout=10&pool_timeout=15&options=-c%20statement_timeout%3D5000&sslmode=require

# Domain configuration
ROOT_DOMAIN=example.com
PUBLIC_BASE_URL=https://dns-api.example.com

# Cloudflare credentials (never expose to students)
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Admin API key — keep secret, used only by administrator
# Generate: echo "admin_dns_$(openssl rand -hex 32)"
ADMIN_API_KEY=admin_dns_xxxxxxxxxxxxxxxxxxxxxxxxxx
